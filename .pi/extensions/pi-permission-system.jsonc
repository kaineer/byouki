{
  "defaultPolicy": {
    "tools": "ask",
    "bash": "ask",
    "mcp": "ask",
    "skills": "ask",
    "special": "ask"
  },
  "tools": {
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "bash": "ask"
  },
  "bash": {
    "ls *": "allow",
    "find *": "allow",
    "grep *": "allow",
    "echo * > /tmp/*": "allow",
    "echo *": "allow",
    "cat *": "allow",
    "* > *": "ask"
  }
}
